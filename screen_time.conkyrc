conky.config = {
    alignment = 'top_right',
    gap_x = 30,
    gap_y = 40,

    background = false,
    update_interval = 5,
    double_buffer = true,

    own_window = true,
    own_window_type = 'desktop',
    own_window_transparent = true,

    use_xft = true,
    font = 'sans:size=12',

    draw_shades = false,
    draw_outline = false,
    draw_borders = false
}

conky.text = [[
${alignc}Screen Time

${voffset 10}
${alignc}${font sans:size=32:bold}${execi 30 ~/screen_time.sh}${font}
]]
